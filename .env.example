# Knovo environment variables.
# Copy to .env.local (git-ignored) and fill in. Use the DEV Supabase project locally;
# PROD values are set in Vercel only. Keep this file in LOCKSTEP with the code: any new
# env var is added here, with an empty value + comment, in the same commit that introduces it.
# Separate dev and prod Supabase projects (see foundation/deployment.md).

# ── Supabase: browser-safe (RLS-bounded) ─────────────────────────────────────
# Project URL. Supabase dashboard → Project Settings → API → Project URL.
NEXT_PUBLIC_SUPABASE_URL=
# Anon / publishable key. Same page → Project API keys → anon (public).
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Supabase: SERVER-ONLY — never expose to the browser, never prefix NEXT_PUBLIC_ ──
# Service-role key BYPASSES RLS; used only in trusted server code, sparingly. Keep secret.
# Supabase dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# ── Google OAuth (admin login) ───────────────────────────────────────────────
# Create a Web OAuth client: Google Cloud Console → APIs & Services → Credentials.
# Configure the same client in Supabase: Authentication → Providers → Google.
# (Supabase performs the OAuth exchange; these are documented here for completeness/lockstep.)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ── Worker API: per-worker bearer tokens (SERVER-ONLY) ───────────────────────
# Tokens the routine workers present to the governed Knovo API (api.knovo.ai). Generate long
# random secrets (e.g. `openssl rand -hex 32`). Each maps to a worker identity + allowed verbs
# in lib/worker-auth.ts. Set the SAME value here (for the API to verify) and in the routine's
# cloud-environment variables (for the worker to send). See docs/routines.md.
KNOVO_WORKER_TOKEN_SCOUT=
KNOVO_WORKER_TOKEN_EDITOR=
KNOVO_WORKER_TOKEN_KEEPER=

# ── Dashboard → worker fire triggers (SERVER-ONLY) ───────────────────────────
# Per-routine API-trigger URL + token from the Claude web app (routine → Add trigger → API →
# Generate token). Lets the admin dashboard fire a worker on demand. Token prefix sk-ant-oat01-.
ROUTINE_SCOUT_FIRE_URL=
ROUTINE_SCOUT_TOKEN=
ROUTINE_EDITOR_FIRE_URL=
ROUTINE_EDITOR_TOKEN=
ROUTINE_KEEPER_FIRE_URL=
ROUTINE_KEEPER_TOKEN=

# Base URL the workers call for the governed API (the worker-API subdomain).
KNOVO_API_BASE=https://api.knovo.ai
